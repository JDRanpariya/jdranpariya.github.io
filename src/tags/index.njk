---
title: "All Tags"
layout: layouts/base
section: "tags index"
permalink: /tags/
---

<section class="max-w-wide mx-auto px-6 py-16 md:py-24 space-y-10">
  <header class="space-y-4">
    <h1 class="font-serif text-display text-ink">All Tags</h1>
  </header>

  {% set excluded = ["all", "nav", "post", "posts", "nowUpdates", "tagList", "odysseys", "library", "lectures", "books", "writings", "papers", "paper", "projects", "reckoningTheDead", "alchemistsHearth", "feedEntries", "__validateFrontmatter"] %}
  <ul class="chip-list leading-loose">
    {% for tag, posts in collections %}
      {% if tag not in excluded %}
        <li>
          <a href="/tags/{{ tag | slugify }}/" class="chip">
            {{ tag }} <span class="text-ink-muted">({{ posts.length }})</span>
          </a>
        </li>
      {% endif %}
    {% endfor %}
  </ul>
</section>
