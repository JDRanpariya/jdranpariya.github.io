---
title: Now | JDRanpariya
layout: layouts/base
section: "now"
---

{% set groupedUpdates = collections.nowUpdates | groupUpdatesByYearMonth %}
<section class="max-w-7xl mx-auto px-6 py-14">
  <div class="grid grid-cols-1 md:grid-cols-10 gap-8">
    {# Left Column (Empty) #}
    <aside class="hidden md:block md:col-span-2 relative">
      <div class="sticky top-16 mt-16">{# Placeholder #}</div>
    </aside>

    {# Main Content #}
    <section class="md:col-span-6 space-y-12" aria-labelledby="update-heading">
      <div class="text-center space-y-4 mb-16">
        <h1 class="text-5xl md:text-6xl font-serif text-accent">Now</h1>
        <p class="font-serif text-md md:text-xl text-secondary max-w-3xl mx-auto leading-relaxed">
          What's actually going on in my life
        </p>
      </div>

      {# Updates #}
      <div class="space-y-6">
        <h2 id="update-heading" class="text-3xl font-serif text-accent"></h2>
        <div id="updates-container">
          {% for update in collections.nowUpdates %}
            {% set dateStringId = update.date | dateToFormat('yyyy-MM-dd') %}
            <div
              id="update-{{ dateStringId }}"
              class="now-update-content prose dark:prose-invert text-primary dark:text-muted text-lg space-y-3 {% if not loop.first %}hidden{% endif %}"
              data-date="{{ dateStringId }}"
              data-formatted-date="{{ update.date | formatDate }}"
            >
              {{ update.templateContent | safe }}
            </div>
          {% else %}
            <p class="text-primary dark:text-muted text-center italic">No updates posted yet.</p>
          {% endfor %}
        </div>
      </div>

      <div class="text-center pt-8">
        {% set latestUpdate = collections.nowUpdates[0] %}
        <p class="text-sm text-muted" id="footer-update-note">
          Latest update:
          {% if latestUpdate %}{{ latestUpdate.date | formatDate }}{% else %}N/A{% endif %}
        </p>
      </div>
    </section>

    {# Right Column (Archive) #}
    <aside class="pt-4 pr-8 hidden md:block md:col-span-2 relative">
      <div class="sticky top-16 mt-16">
        <h2 class="text-2xl font-serif font-semibold mb-4 text-primary">Archive</h2>
        {% if collections.nowUpdates | length > 0 %}
          {% for yearData in groupedUpdates %}
            {% set year = yearData[0] %}
            {% set months = yearData[1] %}
            <details class="group mb-2" {% if loop.first %}open{% endif %}>
              <summary
                class="cursor-pointer font-semibold text-lg py-1 flex justify-between items-center list-none text-primary hover:text-accent transition-colors"
              >
                {{ year }}
                <svg
                  class="text-secondary w-3 h-3 group-open:rotate-180 transition-transform duration-200"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path
                    fill-rule="evenodd"
                    d="M5.23 7.21a.75.75 0 011.06.02L10 11.06l3.71-3.83a.75.75 0 111.08 1.04l-4.25 4.39a.75.75 0 01-1.08 0L5.21 8.27a.75.75 0 01.02-1.06z"
                    clip-rule="evenodd"
                  />
                </svg>
              </summary>
              <div class="pl-4 border-l border-border ml-1 space-y-1 mt-1">
                {% for month, updates in months %}
                  <details class="group/month mt-1">
                    <summary
                      class="cursor-pointer font-medium text-base py-0.5 flex justify-between items-center list-none text-primary hover:text-accent transition-colors"
                    >
                      {{ month }}
                      <svg
                        class="text-secondary w-3 h-3 group-open/month:rotate-180 transition-transform duration-200"
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 20 20"
                        fill="currentColor"
                        aria-hidden="true"
                      >
                        <path
                          fill-rule="evenodd"
                          d="M5.23 7.21a.75.75 0 011.06.02L10 11.06l3.71-3.83a.75.75 0 111.08 1.04l-4.25 4.39a.75.75 0 01-1.08 0L5.21 8.27a.75.75 0 01.02-1.06z"
                          clip-rule="evenodd"
                        />
                      </svg>
                    </summary>
                    <ul
                      class="pl-4 border-l border-border ml-1 py-1 text-sm space-y-0.5 archive-list"
                    >
                      {% for update in updates %}
                        {% set dateStringId = update.date | dateToFormat('yyyy-MM-dd') %}
                        <li>
                          <a
                            href="#update-{{ dateStringId }}"
                            class="archive-link text-primary hover:underline"
                            data-date="{{ dateStringId }}"
                          >
                            {{ update.date | formatDate }}
                          </a>
                        </li>
                      {% endfor %}
                    </ul>
                  </details>
                {% endfor %}
              </div>
            </details>
          {% endfor %}
        {% else %}
          <p class="text-sm text-muted italic">No past updates recorded yet.</p>
        {% endif %}
      </div>
    </aside>

    {# Mobile Archive #}
    <div class="md:hidden mt-12">
      <details class="group" open>
        <summary
          class="text-base font-semibold text-primary flex items-center justify-between list-none cursor-pointer"
        >
          Archive
          <span class="text-xs text-muted">Tap to toggle</span>
        </summary>
        <div class="mt-4 space-y-4">
          {% if collections.nowUpdates | length > 0 %}
            {% for yearData in groupedUpdates %}
              {% set year = yearData[0] %}
              {% set months = yearData[1] %}
              <details class="space-y-2" {% if loop.first %}open{% endif %}>
                <summary
                  class="font-serif text-primary text-lg list-none cursor-pointer flex justify-between items-center"
                >
                  {{ year }}
                  <span class="text-xs text-muted">▼</span>
                </summary>
                <div class="space-y-2 pl-3 border-l border-border/60">
                  {% for month, updates in months %}
                    <details class="space-y-1" {% if loop.first %}open{% endif %}>
                      <summary
                        class="font-medium text-sm tracking-wide text-muted list-none flex justify-between items-center"
                      >
                        {{ month }}
                        <span>▼</span>
                      </summary>
                      <ul class="text-sm archive-list space-y-1">
                        {% for update in updates %}
                          {% set dateStringId = update.date | dateToFormat('yyyy-MM-dd') %}
                          <li>
                            <a
                              href="#update-{{ dateStringId }}"
                              class="archive-link text-primary hover:underline"
                              data-date="{{ dateStringId }}"
                            >
                              {{ update.date | formatDate }}
                            </a>
                          </li>
                        {% endfor %}
                      </ul>
                    </details>
                  {% endfor %}
                </div>
              </details>
            {% endfor %}
          {% else %}
            <p class="text-sm text-muted italic">No past updates recorded yet.</p>
          {% endif %}
        </div>
      </details>
    </div>
  </div>
</section>

<script src="/assets/js/now.js" defer></script>
