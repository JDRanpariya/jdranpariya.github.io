---
title: Now
layout: layouts/base
section: "now"
description: "What Jay's actually up to — a running log of life, work, and whatever's on his mind."
---

{% set groupedUpdates = collections.nowUpdates | groupUpdatesByYearMonth %}
{% set latestUpdate = collections.nowUpdates[0] %}

<section class="max-w-page mx-auto px-6 md:px-8 py-16 md:py-24">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">
    <!-- Main column -->
    <section class="lg:col-span-8 lg:col-start-3" aria-labelledby="now-heading">
      <div class="max-w-reading mx-auto">
        <header class="mb-12 space-y-4">
          <h1 id="now-heading" class="font-serif text-display text-ink">Now</h1>
          <p class="text-lead text-ink-secondary max-w-xl">
            What I'm working on, reading, and stuck on this month.
          </p>
        </header>

        <hr class="post-hero__divider" />

        <div class="space-y-6">
          <h2 id="update-heading" class="font-serif text-h3 text-ink">
            {% if latestUpdate %}
              Update from {{ latestUpdate.date | formatDate }}
            {% else %}
              Latest update
            {% endif %}
          </h2>

          <div id="updates-container" class="space-y-6">
            {% for update in collections.nowUpdates %}
              {% set dateStringId = update.date | dateToFormat("yyyy-MM-dd") %}
              <article
                id="update-{{ dateStringId }}"
                class="now-update-content prose-site {% if not loop.first %}hidden{% endif %}"
                data-date="{{ dateStringId }}"
                data-formatted-date="{{ update.date | formatDate }}"
              >
                {{ update.templateContent | safe }}
              </article>
            {% else %}
              <p class="text-ink-muted italic">No updates posted yet.</p>
            {% endfor %}
          </div>
        </div>

        <p
          id="footer-update-note"
          class="mt-12 pt-6 border-t border-border font-sans text-ui-sm text-ink-muted"
        >
          {% if latestUpdate %}
            Latest update: {{ latestUpdate.date | formatDate }}
          {% else %}
            No updates yet.
          {% endif %}
        </p>

        <!-- Mobile archive (collapses inline under the current update) -->
        <details class="lg:hidden mt-12 pt-6 border-t border-border">
          <summary class="toc-toggle" style="list-style:none">
            <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path
                fill-rule="evenodd"
                d="M5.23 7.21a.75.75 0 011.06.02L10 11.06l3.71-3.83a.75.75 0 111.08 1.04l-4.25 4.39a.75.75 0 01-1.08 0L5.21 8.27a.75.75 0 01.02-1.06z"
                clip-rule="evenodd"
              />
            </svg>
            Archive
          </summary>
          <div class="mt-4 space-y-3">
            {% if collections.nowUpdates | length %}
              {% for yearData in groupedUpdates %}
                {% set year = yearData[0] %}
                {% set months = yearData[1] %}
                <details {% if loop.first %}open{% endif %} class="archive-details text-ui-sm">
                  <summary class="font-sans text-ui text-ink cursor-pointer">{{ year }}</summary>
                  <div class="mt-2 pl-4 border-l border-border space-y-2">
                    {% for month, updates in months %}
                      <details {% if loop.first %}open{% endif %} class="archive-details">
                        <summary class="font-sans text-ui text-ink-muted cursor-pointer">
                          {{ month }}
                        </summary>
                        <ul class="mt-1 pl-4 list-none m-0 p-0 space-y-1 archive-list">
                          {% for update in updates %}
                            {% set dateStringId = update.date | dateToFormat("yyyy-MM-dd") %}
                            <li>
                              <a
                                href="#update-{{ dateStringId }}"
                                class="archive-link font-sans text-ui-sm text-ink-muted hover:text-accent transition-colors duration-base"
                                data-date="{{ dateStringId }}"
                              >
                                {{ update.date | formatDate }}
                              </a>
                            </li>
                          {% endfor %}
                        </ul>
                      </details>
                    {% endfor %}
                  </div>
                </details>
              {% endfor %}
            {% endif %}
          </div>
        </details>
      </div>
    </section>

    <!-- Desktop archive sidebar -->
    <aside class="hidden lg:block lg:col-span-2" aria-label="Archive">
      <div class="sticky top-24">
        <p class="eyebrow mb-4">Archive</p>
        {% if collections.nowUpdates | length %}
          {% for yearData in groupedUpdates %}
            {% set year = yearData[0] %}
            {% set months = yearData[1] %}
            <details class="archive-details mb-3" {% if loop.first %}open{% endif %}>
              <summary
                class="font-sans text-ui font-medium text-ink cursor-pointer hover:text-accent transition-colors duration-base"
              >
                {{ year }}
              </summary>
              <div class="mt-2 pl-3 border-l border-border space-y-1">
                {% for month, updates in months %}
                  <details class="archive-details" {% if loop.first %}open{% endif %}>
                    <summary
                      class="font-sans text-ui-sm text-ink-muted cursor-pointer hover:text-accent transition-colors duration-base"
                    >
                      {{ month }}
                    </summary>
                    <ul class="mt-1 pl-3 list-none m-0 p-0 space-y-1 archive-list">
                      {% for update in updates %}
                        {% set dateStringId = update.date | dateToFormat("yyyy-MM-dd") %}
                        <li>
                          <a
                            href="#update-{{ dateStringId }}"
                            class="archive-link font-sans text-ui-sm text-ink-muted hover:text-accent transition-colors duration-base"
                            data-date="{{ dateStringId }}"
                          >
                            {{ update.date | formatDate }}
                          </a>
                        </li>
                      {% endfor %}
                    </ul>
                  </details>
                {% endfor %}
              </div>
            </details>
          {% endfor %}
        {% else %}
          <p class="text-ui-sm text-ink-muted italic">No past updates.</p>
        {% endif %}
      </div>
    </aside>
  </div>
</section>

<script src="/assets/js/now.js" defer></script>
