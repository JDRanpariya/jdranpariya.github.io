<!-- Top navigation.
     Active-state styling is driven by [aria-current="page"] on the link (see
     .nav-link in src/css/input.css) — no conditional class strings in the
     template.
-->
<nav class="relative z-40" aria-label="Primary">
  <div class="max-w-page mx-auto px-6 md:px-8 py-6 flex items-center justify-between">
    <!-- Wordmark -->
    <a href="/" class="inline-flex items-center font-heading text-2xl text-ink min-h-[44px]">
      <span aria-hidden="true">=^.^=</span>
      <span class="sr-only">Jay Ranpariya — home</span>
    </a>

    <div class="flex items-center gap-6 md:gap-8">
      <!-- Primary links -->
      <ul class="hidden md:flex items-center gap-6 list-none m-0 p-0">
        {%
          set primary = [
            ["/writings", "Writings"],
            ["/library",  "Library"],
            ["/odysseys", "Odysseys"],
            ["/projects", "Projects"],
            ["/now",      "Now"],
            ["/about",    "About"]
          ]
        %}
        {% for item in primary %}
          <li>
            <a
              href="{{ item[0] }}"
              class="nav-link"
              {% if page.url.startsWith(item[0]) %}aria-current="page"{% endif %}
              >{{ item[1] }}</a
            >
          </li>
        {% endfor %}
      </ul>

      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        type="button"
        data-action="toggle-theme"
        class="p-3 rounded-md text-ink hover:text-accent transition-colors duration-base"
        aria-label="Toggle dark mode"
        aria-pressed="false"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
          />
        </svg>
      </button>

      <!-- Mobile menu toggle -->
      <button
        id="mobile-menu-toggle"
        type="button"
        data-action="toggle-mobile-menu"
        class="md:hidden p-3 rounded-md text-ink hover:text-accent transition-colors duration-base"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"
          />
        </svg>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile sheet backdrop -->
<div
  id="menu-backdrop"
  class="fixed inset-0 bg-ink/50 z-40 md:hidden opacity-0 pointer-events-none transition-opacity duration-slow"
  aria-hidden="true"
></div>

<!-- Mobile sheet -->
<aside
  id="mobile-menu"
  class="fixed top-0 right-0 h-full w-80 max-w-sm bg-surface shadow-sheet z-50 md:hidden translate-x-full transition-transform duration-slow ease-[cubic-bezier(0.4,0,0.2,1)]"
  aria-label="Site navigation"
>
  <div class="flex items-center justify-between p-6 border-b border-border">
    <span class="font-serif text-lg text-ink" aria-hidden="true">=^.^=</span>
    <button
      type="button"
      data-action="close-mobile-menu"
      aria-label="Close menu"
      class="p-2 rounded-md text-ink hover:text-accent transition-colors duration-base"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"
        />
      </svg>
    </button>
  </div>

  <ul class="px-6 py-8 space-y-5 list-none m-0">
    {%
      set primary = [
        ["/writings", "Writings"],
        ["/library",  "Library"],
        ["/odysseys", "Odysseys"],
        ["/projects", "Projects"],
        ["/guestbook", "Guestbook"],
        ["/now",      "Now"],
        ["/about",    "About"]
      ]
    %}
    {% for item in primary %}
      <li>
        <a
          href="{{ item[0] }}"
          class="nav-link block py-2 text-lg"
          data-action="close-mobile-menu"
          {% if page.url.startsWith(item[0]) %}aria-current="page"{% endif %}
          >{{ item[1] }}</a
        >
      </li>
    {% endfor %}
  </ul>
</aside>
