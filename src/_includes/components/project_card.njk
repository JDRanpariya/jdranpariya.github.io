<article class="group">
<a href="{{ project.url }}" class="block">
<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 p-6 rounded-xl bg-surface/50 hover:bg-surface transition-all duration-300 hover:shadow-lg">

  <div class="lg:col-span-1">
    {% if project.data.image %}
      <img src="{{ project.data.image }}" alt="{{ project.data.title }}"
        loading="lazy"
        decoding="async"
        class="max-w-sm w-full rounded-lg object-cover aspect-[3/2] shadow-sm group-hover:shadow-md transition-shadow" />
    {% endif %}
  </div>

  <div class="flex flex-col justify-between lg:col-span-2 h-full">
    <div class="space-y-4">

      <div class="flex items-center gap-3">
        <h2 class="text-2xl md:text-3xl font-serif font-medium text-accent group-hover:text-primary transition-colors">
          {{ project.data.title }}
        </h2>
        {% if project.data.status %}
          <span class="text-xs font-sans px-2 py-1 rounded-full
            {% if project.data.status == 'active' %}bg-accent/20 text-accent
            {% else %}bg-muted/20 text-muted{% endif %}">
            {{ project.data.status }}
          </span>
        {% endif %}
      </div>

      {% if project.data.description %}
        <p class="text-base md:text-lg text-muted leading-relaxed">
          {{ project.data.description }}
        </p>
      {% endif %}
    </div>

    <div class="mt-4 flex items-end justify-between">
      {% if project.data.tech %}
        <div class="flex flex-wrap gap-2">
          {% for t in project.data.tech %}
            <span class="text-sm capitalize font-medium px-2 py-1 bg-surface rounded">{{ t }}</span>
          {% endfor %}
        </div>
      {% endif %}
      {% if project.data.published %}
        <span class="text-sm text-muted">{{ project.data.published | formatDate }}</span>
      {% endif %}
    </div>
  </div>

</div>
</a>
</article>
