<!-- JSON-LD Structured Data -->
<script type="application/ld+json">
{%- if section == "writings" %}
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "{{ title }}",
  "description": "{{ description }}",
  "url": "https://jdranpariya.github.io{{ page.url }}",
  "datePublished": "{{ published }}",
  "dateModified": "{{ lastUpdated or published }}",
  "keywords": [{% for tag in tags %}"{{ tag }}"{% if not loop.last %}, {% endif %}{% endfor %}],
  {% if series %}"isPartOf": { "@type": "CreativeWorkSeries", "name": "{{ series.name }}", "position": {{ series.order }} },{% endif %}
  "author": {
    "@type": "Person",
    "name": "JD Ranpariya",
    "url": "https://jdranpariya.github.io/about",
    "sameAs": ["https://github.com/jdranpariya", "https://linkedin.com/in/jdranpariya"]
  },
  "publisher": { "@type": "Person", "name": "JD Ranpariya", "url": "https://jdranpariya.github.io" },
  "mainEntityOfPage": { "@type": "WebPage", "@id": "https://jdranpariya.github.io{{ page.url }}" }
}

{%- elif section == "books" %}
{
  "@context": "https://schema.org",
  "@type": "Review",
  "name": "Review: {{ fullTitle or title }}",
  "description": "{{ description }}",
  "url": "https://jdranpariya.github.io{{ page.url }}",
  "datePublished": "{{ published }}",
  "dateModified": "{{ lastUpdated or published }}",
  "author": {
    "@type": "Person",
    "name": "JD Ranpariya",
    "url": "https://jdranpariya.github.io/about"
  },
  "itemReviewed": {
    "@type": "Book",
    "name": "{{ fullTitle or title }}",
    "author": { "@type": "Person", "name": "{{ author }}" },
    {% if cover %}"image": "{{ cover }}",{% endif %}
    {% if link %}"url": "{{ link }}",{% endif %}
    "keywords": [{% for tag in tags %}"{{ tag }}"{% if not loop.last %}, {% endif %}{% endfor %}]
  }
}

{%- elif section == "lectures" %}
{
  "@context": "https://schema.org",
  "@type": "Review",
  "name": "Notes: {{ fullTitle or title }}",
  "description": "{{ description }}",
  "url": "https://jdranpariya.github.io{{ page.url }}",
  "datePublished": "{{ published }}",
  "dateModified": "{{ lastUpdated or published }}",
  "author": {
    "@type": "Person",
    "name": "JD Ranpariya",
    "url": "https://jdranpariya.github.io/about"
  },
  "itemReviewed": {
    "@type": "Course",
    "name": "{{ fullTitle or title }}",
    "author": { "@type": "Person", "name": "{{ author }}" },
    {% if cover %}"image": "{{ cover }}",{% endif %}
    "keywords": [{% for tag in tags %}"{{ tag }}"{% if not loop.last %}, {% endif %}{% endfor %}]
  }
}

{%- elif section == "odysseys" or section == "odyssey" %}
{
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "headline": "{{ fullTitle or title }}",
  "description": "{{ description }}",
  "url": "https://jdranpariya.github.io{{ page.url }}",
  "datePublished": "{{ published }}",
  "dateModified": "{{ lastUpdated or published }}",
  "keywords": [{% for tag in tags %}"{{ tag }}"{% if not loop.last %}, {% endif %}{% endfor %}],
  "author": {
    "@type": "Person",
    "name": "JD Ranpariya",
    "url": "https://jdranpariya.github.io/about"
  },
  "mainEntityOfPage": { "@type": "WebPage", "@id": "https://jdranpariya.github.io{{ page.url }}" }
}

{%- elif section == "projects" %}
{
  "@context": "https://schema.org",
  "@type": "SoftwareSourceCode",
  "name": "{{ title }}",
  "description": "{{ description }}",
  "url": "https://jdranpariya.github.io{{ page.url }}",
  "datePublished": "{{ published }}",
  "dateModified": "{{ lastUpdated or published }}",
  {% if url %}"codeRepository": "{{ url }}",{% endif %}
  "keywords": [{% for tag in tags %}"{{ tag }}"{% if not loop.last %}, {% endif %}{% endfor %}],
  "author": {
    "@type": "Person",
    "name": "JD Ranpariya",
    "url": "https://jdranpariya.github.io/about"
  }
}

{%- elif section == "writings index" %}
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Writings by JD Ranpariya",
  "description": "Essays and reflections on AI, learning, neuroscience, and living curiously.",
  "url": "https://jdranpariya.github.io/writings/",
  "author": { "@type": "Person", "name": "JD Ranpariya", "url": "https://jdranpariya.github.io/about" }
}

{%- elif section == "projects" and not published %}
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Projects by JD Ranpariya",
  "description": "Things I'm building, tweaking, or just playing around with.",
  "url": "https://jdranpariya.github.io/projects/",
  "author": { "@type": "Person", "name": "JD Ranpariya", "url": "https://jdranpariya.github.io/about" }
}

{%- elif section == "library" %}
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Library of JD Ranpariya",
  "description": "Books, lectures, and papers that shaped my thinking.",
  "url": "https://jdranpariya.github.io/library/",
  "author": { "@type": "Person", "name": "JD Ranpariya", "url": "https://jdranpariya.github.io/about" }
}

{%- elif section == "odysseys" and not published %}
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Odysseys of JD Ranpariya",
  "description": "Long-term explorations into AI, biology, philosophy, and the mapping of human knowledge.",
  "url": "https://jdranpariya.github.io/odysseys/",
  "author": { "@type": "Person", "name": "JD Ranpariya", "url": "https://jdranpariya.github.io/about" }
}

{%- else %}
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "JD Ranpariya",
  "url": "https://jdranpariya.github.io",
  "description": "Exploring the intersection of AI, biology, neuroscience, and embodied cognition.",
  "author": {
    "@type": "Person",
    "name": "JD Ranpariya",
    "url": "https://jdranpariya.github.io/about",
    "sameAs": [
      "https://github.com/jdranpariya",
      "https://linkedin.com/in/jdranpariya",
      "https://www.goodreads.com/user/show/161877825-jay"
    ]
  }
}
{%- endif %}
</script>


