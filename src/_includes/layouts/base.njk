  <!-- Theme initialization to prevent flash.
       localStorage access is wrapped in try/catch because private-browsing
       Safari and storage-disabled contexts throw SecurityError on read;
       without the guard the whole IIFE would crash before <body> renders. -->
  <script>
  (function() {
    let savedTheme = null;
    try { savedTheme = localStorage.getItem('theme'); } catch (e) {}
    const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
    if (savedTheme === 'dark' || (!savedTheme && prefersDark)) {
      document.documentElement.classList.add('dark');
    }
  })();
  </script>
  </head>

  <body class="bg-bg text-ink min-h-screen flex flex-col antialiased"
      data-title="{{ title | safe }}"
      data-section="{{ section | default('general') }}"
      data-tags="{{ tags | default([]) | join(',') }}"
      data-series="{{ series | default('') }}">

  <!-- Keyboard-only: jump past the nav straight to page content. -->
  <a href="#main" class="skip-to-content">Skip to content</a>

  <!-- Navigation -->
  {% include "components/nav.njk" %}

  <!-- Main Content -->
  <main id="main" class="flex-grow" tabindex="-1">
  {{ content | safe }}
  </main>

  <!-- Footer -->
  {% include "components/footer.njk" %}

  <!-- Site scripts (theme toggle, mobile menu, delegated clicks). -->
  <script src="/assets/js/site.js" defer></script>

  </body>
