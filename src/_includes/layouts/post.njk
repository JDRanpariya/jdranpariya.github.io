---
layout: layouts/base.njk
isPostLayout: true
---

<section class="max-w-page mx-auto px-6 md:px-8 py-16 md:py-24">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">
    <!-- ---------------------------------------------------------------- -->
    <!-- Left: TOC (desktop sidebar, collapsible)                          -->
    <!-- ---------------------------------------------------------------- -->
    <aside class="hidden lg:block lg:col-span-2 toc" aria-label="On this page">
      <div class="sticky top-24">
        <button type="button" class="toc-toggle" aria-expanded="true" aria-controls="toc-panel">
          <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path
              fill-rule="evenodd"
              d="M5.23 7.21a.75.75 0 011.06.02L10 11.06l3.71-3.83a.75.75 0 111.08 1.04l-4.25 4.39a.75.75 0 01-1.08 0L5.21 8.27a.75.75 0 01.02-1.06z"
              clip-rule="evenodd"
            />
          </svg>
          On this page
        </button>
        <div id="toc-panel" class="toc-content" aria-hidden="false">{{ content | toc | safe }}</div>
      </div>
    </aside>

    <!-- ---------------------------------------------------------------- -->
    <!-- Center: article                                                   -->
    <!-- <article> is the landmark; outer <main> is in base.njk.           -->
    <!-- ---------------------------------------------------------------- -->
    <article class="lg:col-span-8 lg:col-start-3 xl:col-start-3">
      <div class="max-w-reading mx-auto">
        <!-- Hero -->
        <header class="post-hero">
          {# Eyebrow is only shown when a post is part of a series — that's the only
             case where the label adds information you can't get from the title, the
             URL, or the page context. Category labels ("Writing", "Book", "Paper")
             are redundant and removed. #}
          {% if series and series.name %}
            <p class="post-hero__eyebrow">{{ series.name }} · Part {{ series.order or 1 }}</p>
          {% endif %}

          <h1 class="post-hero__title">{{ title | smartTitleCase }}</h1>

          {% if description %}
            <p class="post-hero__lead">{{ description }}</p>
          {% endif %}

          <p class="post-hero__meta">
            {% if published %}
              <time datetime="{{ published }}">{{ published | formatDate }}</time>
            {% endif %}
            {% if lastUpdated and lastUpdated != published %}
              <span class="whitespace-nowrap"> · Updated {{ lastUpdated | formatDate }}</span>
            {% endif %}
          </p>

          <hr class="post-hero__divider" />
        </header>

        <!-- Mobile TOC (collapsed by default; desktop version is in the sidebar) -->
        <details class="lg:hidden mt-4 mb-8 toc">
          <summary class="toc-toggle" style="list-style:none">
            <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path
                fill-rule="evenodd"
                d="M5.23 7.21a.75.75 0 011.06.02L10 11.06l3.71-3.83a.75.75 0 111.08 1.04l-4.25 4.39a.75.75 0 01-1.08 0L5.21 8.27a.75.75 0 01.02-1.06z"
                clip-rule="evenodd"
              />
            </svg>
            On this page
          </summary>
          <div class="toc-content mt-3">{{ content | toc | safe }}</div>
        </details>

        <!-- Body -->
        <div class="prose-site">{{ content | safe }}</div>

        <!-- ------------------------------------------------------------ -->
        <!-- Post footer: tags + reply CTA. Tags live here (not in hero)  -->
        <!-- so the top of the page stays calm.                            -->
        <!-- ------------------------------------------------------------ -->
        {% if tags or section == "writings" %}
          <footer class="post-footer">
            {% if tags %}
              <div class="post-footer__tags">
                <p class="eyebrow shrink-0">Tagged</p>
                <ul class="chip-list">
                  {% for tag in tags %}
                    <li><a href="/tags/{{ tag | slug }}/" class="chip">{{ tag }}</a></li>
                  {% endfor %}
                </ul>
              </div>
            {% endif %}

            {% if section == "writings" %}
              <div class="post-footer__reply">
                <p>Thoughts on this? I&rsquo;d genuinely like to hear them.</p>
                <a
                  href="mailto:jaydeepranpariya037@gmail.com?subject={{ title | urlencode }}"
                  class="btn-link"
                >
                  Reply by email
                  <svg
                    class="w-3 h-3"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M17 8l4 4m0 0l-4 4m4-4H3"
                    />
                  </svg>
                </a>
              </div>
            {% endif %}
          </footer>
        {% endif %}
      </div>
    </article>

    <!-- ---------------------------------------------------------------- -->
    <!-- Right: sidenote gutter (populated by post.js on                 ) -->
    <!-- ---------------------------------------------------------------- -->
    <aside class="hidden lg:block lg:col-span-2" aria-label="Footnotes">
      <div id="footnotes-sidebar" class="relative pl-2"></div>
    </aside>
  </div>
</section>

<script src="/assets/js/post.js" defer></script>
