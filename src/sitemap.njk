---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---

<?xml version="1.0" encoding="utf-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {%- set site = "https://jdranpariya.github.io" %}
  {#
    Fully automated: emit every page Eleventy built, minus:
      - drafts (status: "draft")
      - explicitly excluded pages (sitemap: false in frontmatter)
      - pages with no permalink (e.g., now/updates with layout:false)
      - the 404 page
  #}
  {%- for item in collections.all %}
    {%- set d = item.data %}
    {%-
      if item.url
      and item.url != false
      and d.status != "draft"
      and d.sitemap != false
      and not item.url.startsWith("/404")
      and not item.url.startsWith("/now/updates/")
    %}
      <url>
        <loc>{{ site }}{{ item.url }}</loc>
        {%- set lastmod = d.lastUpdated or d.published or item.date %}
        {%- if lastmod %}
          <lastmod>{{ lastmod | dateToFormat('yyyy-MM-dd') }}</lastmod>
        {%- endif %}
      </url>
    {%- endif %}
  {%- endfor %}
</urlset>
