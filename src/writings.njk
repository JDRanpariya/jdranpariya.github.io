---
title: Writings By JDRanpariya
description: "Essays and reflections on AI, learning, neuroscience, and living curiously — by JD Ranpariya."
layout: layouts/base
section: "writings index"
---

<section class="max-w-3xl mx-auto px-6 py-24 md:py-32">

  <!-- Header -->
  <div class="text-center mb-16 space-y-3">
    <h1 class="text-5xl md:text-6xl font-serif text-accent">Writings</h1>
    <p class="text-lg text-muted ">
      Thoughts and explorations across AI, neuroscience, biology, and learning.
    </p>
  </div>

  <!-- List of posts -->
  <div class="divide-y divide-border">
    {% for post in collections.writings | sort(true, false, "data.published") %}
      <article class="py-8 space-y-2">
        <div class="flex items-center gap-3 text-sm text-muted">
          <time datetime="{{ post.data.published }}">
            {{ post.data.published | formatDate }}
          </time>
          {% for tag in post.data.tags %}
            <a href="/tags/{{ tag | slug }}/"
               class="bg-accent/10 text-accent px-2 py-0.5 rounded capitalize hover:bg-accent/20 transition-colors">
              {{ tag }}
            </a>
          {% endfor %}
        </div>

        <h2 class="text-2xl font-serif text-primary hover:text-accent transition-colors capitalize">
          <a href="{{ post.url }}">{{ post.data.title }}</a>
        </h2>

        {% if post.data.description %}
          <p class="text-muted leading-relaxed">{{ post.data.description }}</p>
        {% endif %}
      </article>
    {% endfor %}
  </div>

</section>
