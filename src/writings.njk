---
title: Writings
description: "Essays on whatever Jay Ranpariya is thinking through — usually somewhere between science and life."
layout: layouts/base
section: "writings index"
---

<section class="max-w-content mx-auto px-6 py-16 md:py-24">
  <header class="mb-16 space-y-4">
    <h1 class="font-serif text-display text-ink">Writings</h1>
    <p class="text-lead text-ink-secondary max-w-xl">
      Essays on whatever I'm thinking through — usually somewhere between science and life.
    </p>
  </header>

  <ol class="index-list list-none m-0 p-0">
    {% for post in collections.writings | sort(true, false, "data.published") %}
      <li>
        <a href="{{ post.url }}" class="index-row">
          <div class="index-row__meta">
            <time datetime="{{ post.data.published }}">{{ post.data.published | formatDate }}</time>
            {% if post.data.tags and post.data.tags.length %}
              <span aria-hidden="true">·</span>
              <ul class="chip-list">
                {% for tag in post.data.tags %}
                  <li><span class="chip">{{ tag }}</span></li>
                {% endfor %}
              </ul>
            {% endif %}
          </div>
          <h2 class="index-row__title">{{ post.data.title | smartTitleCase }}</h2>
          {% if post.data.description %}
            <p class="index-row__desc">{{ post.data.description }}</p>
          {% endif %}
        </a>
      </li>
    {% endfor %}
  </ol>
</section>
