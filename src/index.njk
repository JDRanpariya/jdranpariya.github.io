<script>
    const facts = [
    "There are more possible iterations of a shuffled deck of cards than there are atoms on Earth.",
    "If you could fold a piece of paper 42 times, it would reach the moon.",
    "Bananas are radioactive enough that truckloads can trigger radiation sensors at ports.",
    "Your brain uses the same amount of power as a 20-watt light bulb, yet outperforms any supercomputer.",
    "Sharks have existed longer than trees - by about 50 million years.",
    "A teaspoon of neutron star would weigh 6 billion tons on Earth.",
    "You've never touched anything - electrons repel, leaving atoms hovering nanometers apart.",
    "The Mantis Shrimp can punch so fast it boils the water around it and creates light.",
    "There's enough DNA in your body to stretch from the Sun to Pluto and back - 17 times.",
    "Cleopatra lived closer to the invention of the iPhone than to the building of the Great Pyramid.",
    "A photon takes 40,000 years to travel from the Sun's core to its surface, then 8 minutes to reach Earth.",
    "If the universe's timeline was a year, humans appeared at 11:58 PM on December 31st."
];
    document.getElementById('fun-fact').textContent = "Fun fact: " + facts[Math.floor(Math.random() * facts.length)];
</script>
