---
layout: layouts/base.njk
title: "Physical AI Researcher & Builder"
description: "Jay Ranpariya's digital garden — writing on physical AI, embodied cognition, and the intersection of biology, neuroscience, and machine learning."
---

<section class="max-w-content mx-auto px-6 py-16 md:py-24 space-y-20 md:space-y-24">
  <!-- Opening -->
  <header class="space-y-6">
    <h1 class="font-serif text-display text-ink">Jay Ranpariya.</h1>
    <p class="text-lead text-ink-secondary max-w-2xl">
      A polymath building understanding of intelligence from molecules to minds. I love reading,
      cooking, and any sport that'll have me. Nothing I care about fits inside one field and most of
      what I build and write starts there.
    </p>
  </header>

  <!-- Recent writing -->
  <section aria-labelledby="home-writings" class="space-y-6">
    <div class="flex items-baseline justify-between gap-4">
      <h2 id="home-writings" class="eyebrow">Recent writings</h2>
      <a
        href="/writings"
        class="font-sans text-ui-sm text-ink-muted hover:text-accent transition-colors duration-base"
      >
        All writings →
      </a>
    </div>

    <ol class="index-list list-none m-0 p-0">
      {% for post in collections.writings | limit(4) %}
        <li>
          <a href="{{ post.url }}" class="index-row">
            <div class="index-row__meta">
              <time datetime="{{ post.data.published }}"
                >{{ post.data.published | formatDate }}</time
              >
            </div>
            <h3 class="index-row__title">{{ post.data.title | smartTitleCase }}</h3>
            {% if post.data.description %}
              <p class="index-row__desc">{{ post.data.description }}</p>
            {% endif %}
          </a>
        </li>
      {% endfor %}
    </ol>
  </section>

  <!-- Other sections -->
  <section aria-labelledby="home-explore" class="space-y-4">
    <h2 id="home-explore" class="eyebrow">Also on this site</h2>
    <ul class="space-y-2 list-none m-0 p-0 font-sans">
      <li>
        <a href="/library" class="text-ink hover:text-accent transition-colors duration-base"
          >Books, lectures, papers →</a
        >
      </li>
      <li>
        <a href="/odysseys" class="text-ink hover:text-accent transition-colors duration-base"
          >Long-running explorations →</a
        >
      </li>
      <li>
        <a href="/projects" class="text-ink hover:text-accent transition-colors duration-base"
          >Things I'm building →</a
        >
      </li>
      <li>
        <a href="/now" class="text-ink hover:text-accent transition-colors duration-base"
          >What I'm doing now →</a
        >
      </li>
    </ul>
  </section>
</section>
