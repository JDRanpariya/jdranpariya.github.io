#!/usr/bin/env sh
# Fail fast on unformatted code and basic build sanity.
# The full check suite (a11y, lighthouse, links) runs in CI.
# Skip with: git commit --no-verify

set -e

echo "→ prettier --check"
bun run format:check || {
  echo "✗ unformatted files — run: bun run format"
  exit 1
}

# Quick dev build (no OG images, no prod optimizations) to catch syntax errors.
# Full build:prod + smoke/a11y/lighthouse tests happen in CI.
echo "→ build (dev)"
bun run build > /dev/null 2>&1 || {
  echo "✗ build failed — run: bun run build"
  exit 1
}

echo "✓ pre-commit checks passed"
