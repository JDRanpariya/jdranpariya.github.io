{
  "name": "personal-site",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@fullhuman/postcss-purgecss": "^6.0.0",
    "@lhci/cli": "^0.14.0",
    "@tailwindcss/typography": "^0.5.16",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.10.21",
    "concurrently": "^9.2.1",
    "del-cli": "^5.1.0",
    "html-minifier": "^4.0.0",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "linkinator": "^7.6.1",
    "luxon": "^3.7.2",
    "markdown-it-link-attributes": "^4.0.1",
    "markdown-it-obsidian-callouts": "^0.3.2",
    "pa11y-ci": "^4.1.0",
    "postcss": "^8.4.47",
    "postcss-cli": "^11.0.0",
    "prettier": "^3.8.3",
    "prettier-plugin-jinja-template": "^2.1.0",
    "start-server-and-test": "^3.0.2",
    "tailwindcss": "^3.4.10",
    "wrangler": "^4.37.1"
  },
  "scripts": {
    "clean": "bunx del build",
    "start": "concurrently \"bunx @11ty/eleventy --serve\" \"bun run css:watch\"",
    "watch": "bunx @11ty/eleventy --watch",
    "build": "ELEVENTY_ENV=dev bunx @11ty/eleventy && bun run css:build",
    "build:prod": "ELEVENTY_ENV=prod bunx @11ty/eleventy && bun run css:build:prod",
    "debug": "DEBUG=* bunx @11ty/eleventy",
    "css:build": "bunx postcss src/css/input.css --o build/css/style.css",
    "css:build:prod": "ELEVENTY_ENV=prod bunx postcss src/css/input.css --o build/css/style.css",
    "css:watch": "bunx postcss src/css/input.css --o build/css/style.css --watch",
    "check": "bun run build:prod && bun run check:smoke && bun run check:links && bun run check:a11y && bun run check:lh",
    "check:smoke": "bun scripts/smoke.js",
    "check:links": "start-server-and-test 'http-server build -p 8082 -s' 8082 'linkinator http://localhost:8082/ --recurse --retry --skip \"^(?!http://localhost:8082)\"'",
    "check:a11y": "bunx start-server-and-test 'bunx http-server build -p 8081 -s' 8081 'bunx pa11y-ci'",
    "check:lh": "bunx lhci autorun",
    "format": "bunx prettier --write .",
    "format:check": "bunx prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-plugin-rss": "^2.0.4",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "@vscode/markdown-it-katex": "^1.1.2",
    "caniuse-lite": "^1.0.30001790",
    "eleventy-plugin-toc": "^1.1.5",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-container": "^4.0.0",
    "markdown-it-footnote": "^4.0.0"
  }
}
